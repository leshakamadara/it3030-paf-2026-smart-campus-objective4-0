# Smart Campus API environment template
# Copy values into your shell environment or deployment secret manager.
# Spring Boot does not automatically load this file unless you add external tooling.

# Database
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/smartcampus
SPRING_DATASOURCE_USERNAME=your_username
SPRING_DATASOURCE_PASSWORD=your_password

# Real Google OAuth2 client credentials (from Google Cloud Console)
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_CLIENT_ID=your_google_client_id
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_CLIENT_SECRET=your_google_client_secret

# Redirect URL used by OAuth2SuccessHandler after Google login
APP_OAUTH2_AUTHORIZED_REDIRECT_URI=http://localhost:5173/auth/callback

# JWT (use a strong base64-encoded key)
APP_JWT_SECRET=replace_with_strong_base64_secret
APP_JWT_EXPIRATION_MILLISECONDS=86400000

# Keep disabled in non-dev environments
APP_AUTH_ALLOW_DUMMY_LOGIN=false
